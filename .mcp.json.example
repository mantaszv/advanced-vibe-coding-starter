{
  "_comment": "Nukopijuokite į .mcp.json (jis .gitignore'e) ir paleiskite `chmod 600 .mcp.json`. Raw raktų ČIA NERAŠOME, naudokite ${VAR} substituciją, o env var'us pildykite iš OS keychain (macOS: Keychain Access, Linux: secret-tool, Windows: Credential Manager).",
  "mcpServers": {
    "supabase": {
      "command": "npx",
      "args": ["-y", "@supabase/mcp-server-supabase@latest"],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "${SUPABASE_ACCESS_TOKEN}",
        "SUPABASE_PROJECT_REF": "${SUPABASE_PROJECT_REF}"
      }
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "stripe": {
      "command": "npx",
      "args": ["-y", "@stripe/mcp@latest", "--tools=all"],
      "env": {
        "STRIPE_SECRET_KEY": "${STRIPE_SECRET_KEY}"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "vercel": {
      "type": "http",
      "url": "https://mcp.vercel.com"
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    }
  }
}
