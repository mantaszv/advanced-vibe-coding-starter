{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run build)",
      "Bash(npm run lint)",
      "Bash(npm run lint:*)",
      "Bash(npm run test)",
      "Bash(npm run test:*)",
      "Bash(npm run dev)",
      "Bash(npm install)",
      "Bash(npm install *)",
      "Bash(npm ci)",
      "Bash(pnpm *)",
      "Bash(bun *)",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit -m *)",
      "Bash(git push)",
      "Bash(git pull)",
      "Bash(git checkout *)",
      "Bash(git branch)",
      "Bash(git stash *)",
      "Bash(npx supabase *)",
      "Bash(npx vercel *)",
      "Bash(npx playwright *)",
      "Bash(mempalace *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(tree *)",
      "Edit(src/**)",
      "Edit(docs/**)",
      "Edit(supabase/migrations/**)",
      "Edit(wiki/**)",
      "Edit(raw/**)",
      "Edit(.claude/agents/**)",
      "Edit(tests/**)",
      "Edit(e2e/**)",
      "Read(**)",
      "WebFetch(domain:docs.stripe.com)",
      "WebFetch(domain:supabase.com)",
      "WebFetch(domain:nextjs.org)",
      "WebFetch(domain:vercel.com)",
      "WebFetch(domain:playwright.dev)",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:github.com)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(sudo *)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * | bash)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git branch -D *)",
      "Bash(npx supabase db reset*)",
      "Bash(npx supabase db push --db-url*)",
      "Bash(psql *)",
      "Bash(npx vercel --prod*)",
      "Bash(npx vercel deploy --prod*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(.mcp.json)",
      "Edit(package-lock.json)",
      "Edit(pnpm-lock.yaml)",
      "Edit(bun.lockb)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(.mcp.json)",
      "WebFetch(domain:*)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(gh pr create*)",
      "Bash(gh pr merge*)",
      "Bash(npm publish*)",
      "Edit(package.json)",
      "Edit(.github/workflows/**)"
    ]
  },
  "model": "opus",
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "mempalace hook run --hook session-start --harness claude-code",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "git diff --quiet && git diff --cached --quiet || echo '[CWK] Yra uncommitted pakeitimų. Prieš pabaigą paleiskite: npm run build && npm run lint && npx vitest run'",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "mempalace hook run --hook stop --harness claude-code",
            "timeout": 30
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "mempalace hook run --hook precompact --harness claude-code",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
