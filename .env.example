# Advanced Vibe Coding Starter .env.example
# Copy this file to .env.local and replace placeholders with real values.
# Never commit real secrets to the repository.

# === App ===
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# === Stripe optional ===
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_PRICE_ID_MONTHLY=price_your-monthly-price-id
STRIPE_PRICE_ID_YEARLY=price_your-yearly-price-id

# === Resend optional ===
RESEND_API_KEY=re_your-resend-api-key